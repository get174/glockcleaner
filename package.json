{
  "name": "glockcleaner",
  "version": "1.1.0",
  "description": "Application de nettoyage PC pour Windows - Version améliorée",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "electron-builder ",
    "publish": "electron-builder --publish always",
    "dist": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "keywords": [
    "electron",
    "cleanup",
    "windows",
    "optimizer"
  ],
  "author": "Glok Team",
  "license": "ISC",
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "fs-extra": "^11.3.5"
  },
  "build": {
    "appId": "com.get174.glockcleaner",
    "productName": "GlockCleaner",
    "directories": {
      "output": "nsis"
    },
    "files": [
      "**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": "nsis-web",
      "icon": "build/installerIcon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/installerIcon.ico",
      "installerSidebar": "assets/installerSidebar.bmp",
      "installerHeader": "assets/installerHeader.bmp",
      "uninstallerSidebar": "assets/uninstallerSidebar.bmp"
    },
    "publish": {
      "provider": "github",
      "owner": "get174",
      "repo": "glockcleaner"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  }
}
